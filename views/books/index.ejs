<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Library Management System</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: "#4F46E5",
                        secondary: "#6366F1",
                        success: "#16A34A",
                        danger: "#DC2626",
                        dark: "#0F172A"
                    }
                }
            }
        }
    </script>
</head>

<body class="bg-slate-100">

    <!-- Navbar -->

    <nav class="bg-white shadow-md sticky top-0 z-50">

        <div class="max-w-7xl mx-auto px-6">

            <div class="flex justify-between items-center h-16">

                <div class="flex items-center gap-3">

                    <div
                        class="w-11 h-11 rounded-xl bg-indigo-600 flex items-center justify-center text-white text-xl font-bold shadow-lg">
                        📚
                    </div>

                    <div>

                        <h1 class="text-2xl font-bold text-slate-800">
                            LibraryMS
                        </h1>

                        <p class="text-xs text-slate-500">
                            Manage your books efficiently
                        </p>

                    </div>

                </div>

                <a href="/books/new"
                    class="bg-indigo-600 hover:bg-indigo-700 transition text-white px-5 py-2 rounded-lg font-semibold shadow-md">
                    + Add Book
                </a>

            </div>

        </div>

    </nav>

    <!-- Hero -->

    <section
        class="bg-gradient-to-r from-indigo-700 via-indigo-600 to-blue-600 text-white">

        <div class="max-w-7xl mx-auto px-6 py-16">

            <div class="max-w-3xl">

                <h1 class="text-5xl font-extrabold leading-tight">

                    Library Management
                    <span class="text-blue-200">
                        Dashboard
                    </span>

                </h1>

                <p class="mt-5 text-lg text-blue-100">

                    Organize your collection, manage books,
                    keep track of availability and maintain
                    your digital library with ease.

                </p>

                <div class="mt-8 flex gap-4">

                    <a href="/books/new"
                        class="bg-white text-indigo-700 px-6 py-3 rounded-xl font-semibold hover:scale-105 transition shadow-lg">

                        Add New Book

                    </a>

                    <a href="#books"
                        class="border border-white px-6 py-3 rounded-xl hover:bg-white hover:text-indigo-700 transition">

                        Browse Books

                    </a>

                </div>

            </div>

        </div>

    </section>

    <!-- Search Section -->

    <section id="books" class="max-w-7xl mx-auto px-6 py-10">

        <div class="bg-white rounded-2xl shadow-lg p-6">

            <div class="flex justify-between items-center mb-6">

                <div>

                    <h2 class="text-3xl font-bold text-slate-800">
                        All Books
                    </h2>

                    <p class="text-slate-500">
                        Total Books :
                        <span class="font-semibold">
                            <%= books.length %>
                        </span>
                    </p>

                </div>

                <a href="/books/new"
                    class="bg-green-600 hover:bg-green-700 text-white px-5 py-3 rounded-xl font-semibold shadow">

                    + New Book

                </a>

            </div>

            <form
                action="/books"
                method="GET"
                class="grid md:grid-cols-3 gap-5">

                <input
                    type="text"
                    name="search"
                    placeholder="🔍 Search books..."
                    value="<%= search || '' %>"
                    class="border border-slate-300 rounded-xl px-5 py-3 outline-none focus:ring-4 focus:ring-indigo-200">

                <select
                    name="category"
                    class="border border-slate-300 rounded-xl px-5 py-3 outline-none focus:ring-4 focus:ring-indigo-200">

                    <option value="">All Categories</option>

                    <option value="Programming"
                        <%= category==="Programming" ? "selected" : "" %>>
                        Programming
                    </option>

                    <option value="Finance"
                        <%= category==="Finance" ? "selected" : "" %>>
                        Finance
                    </option>

                    <option value="Self Help"
                        <%= category==="Self Help" ? "selected" : "" %>>
                        Self Help
                    </option>

                    <option value="Fantasy"
                        <%= category==="Fantasy" ? "selected" : "" %>>
                        Fantasy
                    </option>

                </select>

                <button
                    class="bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-semibold transition">

                    Search

                </button>

            </form>

        </div>

        <!-- Book Grid Starts -->

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mt-10">

            <% if (books.length === 0) { %>

            <div class="col-span-full">

                <div class="bg-white rounded-2xl shadow-lg p-12 text-center">

                    <div class="text-7xl mb-4">
                        📚
                    </div>

                    <h2 class="text-3xl font-bold text-slate-800">
                        No Books Found
                    </h2>

                    <p class="text-slate-500 mt-3">
                        Your library is empty. Start by adding your first book.
                    </p>

                    <a href="/books/new"
                        class="inline-block mt-6 bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-xl font-semibold transition">

                        + Add First Book

                    </a>

                </div>

            </div>

        <% } %>

        <% books.forEach(book => { %>

            <div
                class="bg-white rounded-2xl shadow-lg hover:shadow-2xl transition duration-300 overflow-hidden hover:-translate-y-2">

                <!-- Card Header -->

                <div
                    class="bg-gradient-to-r from-indigo-600 to-blue-600 h-28 flex items-center justify-center">

                    <span class="text-6xl">
                        📖
                    </span>

                </div>

                <!-- Card Body -->

                <div class="p-6">

                    <h2 class="text-2xl font-bold text-slate-800">

                        <%= book.title %>

                    </h2>

                    <p class="text-slate-500 mt-2">

                        by <span class="font-semibold"><%= book.author %></span>

                    </p>

                    <!-- Price -->

                    <div class="mt-5 flex justify-between items-center">

                        <span
                            class="bg-green-100 text-green-700 px-4 py-2 rounded-full font-semibold">

                            ₹ <%= book.price %>

                        </span>

                        <% if(book.available){ %>

                            <span
                                class="bg-green-100 text-green-700 px-4 py-2 rounded-full text-sm font-semibold">

                                ✅ Available

                            </span>

                        <% } else { %>

                            <span
                                class="bg-red-100 text-red-700 px-4 py-2 rounded-full text-sm font-semibold">

                                ❌ Unavailable

                            </span>

                        <% } %>

                    </div>

                    <!-- Category -->

                    <div class="mt-5">

                        <span
                            class="inline-block bg-indigo-100 text-indigo-700 px-4 py-2 rounded-full text-sm font-medium">

                            <%= book.category %>

                        </span>

                    </div>

                    <!-- Buttons -->

                    <div class="mt-8 flex gap-3">

                        <a
                            href="/books/<%= book._id %>"
                            class="flex-1 text-center bg-indigo-600 hover:bg-indigo-700 text-white py-3 rounded-xl font-semibold transition">

                            View

                        </a>

                        <a
                            href="/books/<%= book._id %>/edit"
                            class="flex-1 text-center bg-yellow-500 hover:bg-yellow-600 text-white py-3 rounded-xl font-semibold transition">

                            Edit

                        </a>

                    </div>

                    <!-- Delete -->

                    <form
                        action="/books/<%= book._id %>?_method=DELETE"
                        method="POST"
                        class="mt-3">

                        <button
                            onclick="return confirm('Delete this book?')"
                            class="w-full bg-red-600 hover:bg-red-700 text-white py-3 rounded-xl font-semibold transition">

                            Delete

                        </button>

                    </form>

                </div>

            </div>

        <% }) %>

    </div>

</section>

<!-- Footer -->

<footer class="mt-16 bg-slate-900 text-white">

    <div class="max-w-7xl mx-auto px-6 py-10">

        <div class="flex flex-col md:flex-row justify-between items-center gap-4">

            <div>

                <h2 class="text-2xl font-bold">

                    📚 Library Management System

                </h2>

                <p class="text-slate-400 mt-2">

                    Built with Express, MongoDB, EJS & Tailwind CSS

                </p>

            </div>

            <div class="text-slate-400">

                © 2026 All Rights Reserved

            </div>

        </div>

    </div>

</footer>

</body>

</html>        